{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "instructions": [
    "~/.config/opencode/GERAIS.md",
    "./system/objectivity.md"
  ],
  "plugin": [
    "./plugins/path-boundary.ts",
    "./plugins/audit-logger.ts",
    "./plugins/status-injector.ts",
    "./plugins/native-sandbox.ts",
    "./plugins/context-compressor.ts",
    "./plugins/prompt-cache-prefixer.ts",
    "./plugins/token-budget.ts",
    "./plugins/structured-thinking.ts"
  ],
  "experimental": {
    "frontendContextFirst": true,
    "_comment": "v6.5.0 — habilita novo fluxo frontend (context-first + grill-me). Set false para reverter para o legacy behavior."
  },
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "todoread": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow",
    "task": "deny"
  },
  "agent": {
    "frontend": {
      "tools": {
        "skill": true
      },
      "permission": {
        "write": {
          "src/**": "allow",
          "public/**": "allow",
          ".harness/decisions/**": "allow",
          "**/*.stories.tsx": "allow",
          "**/*.stories.ts": "allow",
          "**/*.test.ts": "deny",
          "**/*.test.tsx": "deny",
          "**/*.spec.ts": "deny",
          "**/*.spec.tsx": "deny",
          "tests/**": "deny",
          "test/**": "deny",
          "qa/**": "deny",
          "e2e/**": "deny"
        },
        "edit": {
          "src/**": "allow",
          "public/**": "allow",
          ".harness/decisions/**": "allow",
          "**/*.stories.tsx": "allow",
          "**/*.stories.ts": "allow",
          "**/*.test.ts": "deny",
          "**/*.test.tsx": "deny",
          "**/*.spec.ts": "deny",
          "**/*.spec.tsx": "deny",
          "tests/**": "deny",
          "test/**": "deny",
          "qa/**": "deny",
          "e2e/**": "deny"
        },
        "skill": {
          "frontend-*": "allow",
          "grill-me": "allow",
          "docs-curator": "allow",
          "decision-log": "allow",
          "design-system": "allow",
          "backend-*": "deny",
          "qa-e2e": "deny",
          "security-audit": "deny",
          "lgpd-compliance": "deny"
        }
      }
    },
    "backend": {
      "tools": {
        "skill": true
      },
      "permission": {
        "write": {
          "src/**": "allow",
          "server/**": "allow",
          "api/**": "allow",
          "prisma/**": "allow",
          "migrations/**": "allow",
          "tests/**": "allow",
          "**/*.test.ts": "allow",
          "**/*.spec.ts": "allow"
        },
        "skill": {
          "backend-*": "allow",
          "grill-me": "allow",
          "decision-log": "allow",
          "security-audit": "allow",
          "lgpd-compliance": "allow",
          "frontend-*": "deny",
          "qa-e2e": "deny"
        }
      }
    },
    "documenter": {
      "tools": {
        "skill": true
      },
      "permission": {
        "write": {
          "AGENTS.md": "allow",
          "**/AGENTS.md": "allow",
          ".harness/RAG/**": "allow",
          ".harness/.agmd-hashes.json": "allow",
          "templates/**": "allow",
          "docs/**": "allow"
        },
        "skill": {
          "docs-curator": "allow",
          "grill-me": "allow",
          "decision-log": "allow"
        }
      }
    },
    "tester": {
      "tools": {
        "skill": true
      },
      "permission": {
        "write": {
          "tests/**": "allow",
          "qa/**": "allow",
          "e2e/**": "allow",
          "playwright/**": "allow",
          ".harness/tester/**": "allow"
        },
        "skill": {
          "qa-e2e": "allow",
          "grill-me": "allow",
          "decision-log": "allow"
        }
      }
    },
    "orchestrator": {
      "tools": {
        "skill": true,
        "task": true
      },
      "permission": {
        "skill": {
          "*": "allow"
        }
      }
    },
    "qa-gate": {
      "tools": {
        "skill": true
      },
      "permission": {
        "read": "allow",
        "skill": {
          "qa-e2e": "allow"
        }
      }
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp"
      ]
    },
    "drawio": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@drawio/mcp"
      ]
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp",
        "--autoConnect"
      ]
    },
    "pencil": {
      "command": [
        "/home/kingdev/.pencil/mcp/devin/out/mcp-server-linux-x64",
        "--app",
        "devin",
        "--agent",
        "openCodeCLI"
      ],
      "enabled": false,
      "type": "local"
    },
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "enabled": true,
      "headers": {
        "X-Goog-Api-Key": "${env:STITCH_API_KEY}"
      }
    },
    "duckduckgo-search": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "duckduckgo-mcp-server"
      ]
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-55f0c677-1371-4a7a-99bf-040726afbb46"
      }
    }
  },
  "default_agent": "orchestrator"
}
