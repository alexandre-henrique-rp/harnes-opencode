{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "instructions": [
    "~/.config/opencode/GERAIS.md",
    "./system/objectivity.md"
  ],
  "plugin": [
    "./plugins/path-boundary.ts",
    "./plugins/audit-logger.ts",
    "./plugins/status-injector.ts",
    "./plugins/native-sandbox.ts",
    "./plugins/context-compressor.ts",
    "./plugins/prompt-cache-prefixer.ts",
    "./plugins/token-budget.ts",
    "./plugins/structured-thinking.ts"
  ],
  "experimental": {
    "frontendContextFirst": true,
    "_comment": "v6.5.0 — habilita novo fluxo frontend (context-first + grill-me). Set false para reverter para o legacy behavior."
  },
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "todoread": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow",
    "task": "deny"
  },
  "agent": {
    "frontend": {
      "tools": {
        "skill": true
      },
      "permission": {
        "write": {
          "allow": [
            "src/**",
            "public/**",
            ".harness/decisions/**",
            "**/*.stories.tsx",
            "**/*.stories.ts"
          ],
          "deny": [
            "**/*.test.ts",
            "**/*.test.tsx",
            "**/*.spec.ts",
            "**/*.spec.tsx",
            "tests/**",
            "test/**",
            "qa/**",
            "e2e/**"
          ]
        },
        "edit": {
          "allow": [
            "src/**",
            "public/**",
            ".harness/decisions/**",
            "**/*.stories.tsx",
            "**/*.stories.ts"
          ],
          "deny": [
            "**/*.test.ts",
            "**/*.test.tsx",
            "**/*.spec.ts",
            "**/*.spec.tsx",
            "tests/**",
            "test/**",
            "qa/**",
            "e2e/**"
          ]
        },
        "skill": {
          "frontend-*": "allow",
          "grill-me": "allow",
          "docs-curator": "allow",
          "decision-log": "allow",
          "design-system": "allow",
          "backend-*": "deny",
          "qa-e2e": "deny",
          "security-audit": "deny",
          "lgpd-compliance": "deny"
        }
      }
    },
    "backend": {
      "tools": {
        "skill": true
      },
      "permission": {
        "write": {
          "allow": [
            "src/**",
            "server/**",
            "api/**",
            "prisma/**",
            "migrations/**",
            "tests/**",
            "**/*.test.ts",
            "**/*.spec.ts"
          ]
        },
        "skill": {
          "backend-*": "allow",
          "grill-me": "allow",
          "decision-log": "allow",
          "security-audit": "allow",
          "lgpd-compliance": "allow",
          "frontend-*": "deny",
          "qa-e2e": "deny"
        }
      }
    },
    "documenter": {
      "tools": {
        "skill": true
      },
      "permission": {
        "write": {
          "allow": [
            "AGENTS.md",
            "**/AGENTS.md",
            ".harness/RAG/**",
            ".harness/.agmd-hashes.json",
            "templates/**",
            "docs/**"
          ]
        },
        "skill": {
          "docs-curator": "allow",
          "grill-me": "allow",
          "decision-log": "allow"
        }
      }
    },
    "tester": {
      "tools": {
        "skill": true
      },
      "permission": {
        "write": {
          "allow": [
            "tests/**",
            "qa/**",
            "e2e/**",
            "playwright/**",
            ".harness/tester/**"
          ]
        },
        "skill": {
          "qa-e2e": "allow",
          "grill-me": "allow",
          "decision-log": "allow"
        }
      }
    },
    "orchestrator": {
      "tools": {
        "skill": true,
        "task": true
      },
      "permission": {
        "skill": {
          "*": "allow"
        }
      }
    },
    "qa-gate": {
      "tools": {
        "skill": true
      },
      "permission": {
        "read": "allow",
        "skill": {
          "qa-e2e": "allow"
        }
      }
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp"
      ]
    },
    "drawio": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@drawio/mcp"
      ]
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp",
        "--autoConnect"
      ]
    },
    "pencil": {
      "command": [
        "/home/kingdev/.pencil/mcp/devin/out/mcp-server-linux-x64",
        "--app",
        "devin",
        "--agent",
        "openCodeCLI"
      ],
      "enabled": false,
      "type": "local"
    },
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "enabled": true,
      "headers": {
        "X-Goog-Api-Key": "${env:STITCH_API_KEY}"
      }
    },
    "duckduckgo-search": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "duckduckgo-mcp-server"
      ]
    },
    "context7": {
      "type": "local",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": ""
      },
      "command": [
        "npx",
        "-y",
        "ctx7"
      ]
    }
  },
  "contextCompressor": {
    "enabled": true,
    "threshold": 1000,
    "maxOutputTokens": 500,
    "model": "haiku",
    "preservePatterns": [
      "AGENTS\\.md$",
      "package\\.json$",
      "\\.test\\.",
      "tsconfig\\.json$"
    ]
  },
  "promptCachePrefixer": {
    "enabled": true,
    "cacheBreakpointAfter": "skills",
    "emitMetrics": true
  },
  "tokenBudget": {
    "enabled": true,
    "maxContextTokens": 200000,
    "compactThreshold": 0.5,
    "warnThreshold": 0.8,
    "haltThreshold": 0.95,
    "haltBehavior": "compact"
  },
  "structuredThinking": {
    "enabled": true,
    "requireSelfCheck": true,
    "selfCheckCategories": [
      "spec-coverage",
      "edge-cases",
      "test-coverage",
      "security",
      "performance"
    ],
    "stripThinkingFromOutput": true
  },
  "auditLogger": {
    "costConfig": {
      "inputPer1M": 3.0,
      "outputPer1M": 15.0,
      "cacheReadPer1M": 0.30,
      "cacheWritePer1M": 3.75
    }
  },
  "default_agent": "orchestrator"
}
