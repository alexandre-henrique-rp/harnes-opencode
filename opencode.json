{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "~/.config/opencode/GERAIS.md"
  ],
  "plugin": [
    "./plugins/path-boundary.ts",
    "./plugins/audit-logger.ts",
    "./plugins/status-injector.ts"
  ],
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "todoread": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow",
    "task": "deny"
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ]
    },
    "drawio": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@drawio/mcp"
      ]
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--autoConnect"
      ]
    },
    "pencil": {
      "command": [
        "/home/kingdev/.pencil/mcp/devin/out/mcp-server-linux-x64",
        "--app",
        "devin",
        "--agent",
        "openCodeCLI"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "default_agent": "orchestrator"
}
