{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "~/.config/opencode/GERAIS.md"
  ],
  "plugin": [
    "./plugins/path-boundary.ts",
    "./plugins/audit-logger.ts",
    "./plugins/status-injector.ts"
  ],
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "todoread": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow",
    "task": "deny"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"]
    }
  },
  "default_agent": "orchestrator"
}
